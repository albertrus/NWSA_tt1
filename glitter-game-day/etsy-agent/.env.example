# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Etsy Open API v3 ──────────────────────────────────────────────────────────
# 1. Create an app at https://www.etsy.com/developers/register
# 2. Use the OAuth2 flow to obtain an access token for your shop
# 3. Find your shop ID in Etsy Shop Manager → Settings → Info & Appearance

ETSY_API_KEY=your_etsy_keystring_here
ETSY_ACCESS_TOKEN=your_etsy_oauth_access_token_here
ETSY_SHOP_ID=glittergameday
